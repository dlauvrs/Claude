# ============================================================
# Next.js — Auto Peças Dashboard
# Copy this file to .env.local and fill in all values
# ============================================================

# Google Sheets (read job data)
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Paste the private key from your service account JSON, replacing newlines with \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# App URL (used in n8n WhatsApp messages to link to this dashboard)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================================
# n8n Environment Variables (set in n8n Cloud → Settings → Variables)
# ============================================================

# Z-API
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=

# Google
# GEMINI_API_KEY=
# GOOGLE_DRIVE_FOLDER_ID=   (Drive folder ID for processed images)
# GOOGLE_DRIVE_ACCESS_TOKEN= (Use n8n Google Drive credential instead)

# PhotoRoom
# PHOTOROOM_API_KEY=

# Mercado Livre
# ML_CLIENT_ID=
# ML_CLIENT_SECRET=
# ML_ACCESS_TOKEN=         (refreshed automatically by wf-ml-token-refresh)
# ML_REFRESH_TOKEN=

# Admin phone for error alerts (international format, no +)
# ADMIN_PHONE=5511999999999
